
mapfab(raw, "dwambo.mapfab", "chr", "palette", "metatiles", "level")

data /romdata
    [] start_screen_bytes
        file(raw, "startscr.nam")
    [] help_screen_bytes
        file(raw, "helpscr.nam")

// Square Sides Color enums
ct U VIOLET=0
ct U RED=1
ct U GREEN=2
ct U YELLOW=3

// rotation directions
ct U ROT_CW=0
ct U ROT_CCW=1

ct U ANIM_DELAY=5 // num frame the rotation animation slows down
ct U NUM_ROT_ANIM_FR=5 // num frames the rotation animation has

// we have from 2 to 9 squares in a level, all with 4 sides
struct Square
    Bool active // it might be that not all squares are active in a level
    U north
    U south
    U east
    U west

ct U MAX_PPUOPS_PENDING = 100 // max number of queued PPU OPerations

vars /game_vars

    // these vars contain the metatile map of the current level
    U[16*15] level_mt_map // current screen map of metatiles in RAM
    //pointer to the arrays of the 2x2 tiles (and attr) that make every metatile
    CC/metatiles mt_nw
    CC/metatiles mt_ne
    CC/metatiles mt_sw
    CC/metatiles mt_se
    CC/metatiles mt_attr
    //
    U[16*15] inter_scr_mt_map // screen map of preloaded metatiles of dwambo screen in RAM
    U[16*15] pr_lvl_scr_mt_map // screen map of the preloaded next level metatiles in RAM
    //

    // these vars control the PPU QUEUE
    U num_ppuops_in_queue=0
    U ppuops_queue_index=0
    U[MAX_PPUOPS_PENDING] ppuop_col
    U[MAX_PPUOPS_PENDING] ppuop_row
    U[MAX_PPUOPS_PENDING] ppuop_new_metatile
    //

    // these vars contain the squares in the level and their positions on screen
    Square[9] level_squares
    Square[9] solved_squares // these contain the solved squares, so when you press select, it solves automatically
    U[9] squares_x_coords = U[9](3, 7, 11,   3, 7, 11,   3, 7, 11)
    U[9] squares_y_coords = U[9](2, 2, 2,   6, 6, 6,   10, 10, 10)
    //
    U[9] squares_by_col = U[9](0, 1, 2,   0, 1, 2,   0, 1, 2)
    U[9] squares_by_row = U[9](0, 0, 0,   1, 1, 1,   2, 2, 2)
    //

    // these vars contain the square selector vars
    U selector_sprite_x
    U selector_sprite_y
    U square_selector = 5 // which square the selector is in, vals 1..9
    U[9] sel_spr_x = U[9](48, 112, 176,   48, 112, 176,   48, 112, 176)
    U[9] sel_spr_y = U[9](32, 32, 32,   96, 96, 96,   160, 160, 160)

    // rng
    U rnd_tmp // it's better to leave it uninitialized because when we enter a mode, it sets to default again (not what we want)
    U[16] rotation_table = U[16](1, 4, 2, 1, 3, 2, 1, 4, 3, 2, 1, 2, 1, 3, 4, 2) // random positions to randomize levels. CAN'T BE 0 due to a randomize_lvl_() bug

    U current_level

    Bool during_animation=true
    U[9] square_center_x = U[9](48+16, 112+16, 176+16,   48+16, 112+16, 176+16,   48+16, 112+16, 176+16)
    U[9] square_center_y = U[9](32+16, 32+16, 32+16,   96+16, 96+16, 96+16,   160+16, 160+16, 160+16)
    U anim_frame=0
    U anim_delay_counter=0
    U[4] side_spr_table_h1 = U[4]($34, $35, $32, $33)
    U[4] side_spr_table_h2 = U[4]($44, $45, $42, $43)
    U[4] side_spr_table_v1 = U[4]($14, $24, $16, $26)
    U[4] side_spr_table_v2 = U[4]($15, $25, $17, $27)


////////

// entrance point NMI
nmi main_nmi() 
    // Update OAM and poll the pads:
    ppu_upload_oam_poll_pads(0)
    // Turn on rendering:
    {PPUMASK}(PPUMASK_ON | PPUMASK_NO_CLIP)
    // Reset the scroll
    ppu_reset_scroll(0, 0)
    //
    rnd_tmp+=1 // change the xor rng seed
    if (rnd_tmp==0) // if the xor rng seed is 0, the result always is 0
        rnd_tmp=1
    //

// entrance point function
mode main()
: nmi main_nmi
    // init vars
    current_level=0
    //
    {PPUCTRL}(0)  // Reset PPU control register for new level
    {PPUMASK}(0) // Reset PPU mask register for new level
    hide_oam(0)// Clear OAM to start fresh
    load_screen(@lev_start) // loads a screen in mapfab. I only use it to get the palettes. The namespace is overwritten. //ToDo: make it load palette only?
    preload_screens(@lev_dwambo, @lev_level5) // preloads the DWAMBO screen and the next level into its matching variables in RAM
    //
    // load start screen made in NEXXT whose data is in ROM start screen uses the upper 256 set of chr
    ppu_reset_addr($2000)
    for UU i=0; i<1024; i+=1
        {PPUDATA}(@start_screen_bytes{i})
    //
    // Tell the NES to trigger NMI once per frame, and change the BG pattern table addr, since the start src uses the upper ones:
    {PPUCTRL}(PPUCTRL_NMI_ON|PPUCTRL_BG_PT_1000)
    //
    U spriterot=0
    U current_selection=0 // intro screen, which option is selected, 0 or 1
    //
    while true
        update_pads()
        //
        // update shown sprites
        U i=0
        U sprnum
        U spritex=88
        U spritey=176
        //
        if (current_selection>0)
            spritey+=16
        sprnum=72+((spriterot>>2) & 7)
        spriterot+=1
        //
        set_oam_x(i, spritex) // x-position
        set_oam_y(i, spritey) // y-position
        set_oam_p(i, sprnum) // tile
        set_oam_a(i, 0)  // options
        i+=4
        set_oam_x(i, spritex+88) // x-position
        set_oam_y(i, spritey) // y-position
        set_oam_p(i, sprnum) // tile
        set_oam_a(i, 0)  // options
        i+=4
        hide_oam(i)// Clear the remainder of OAM
        //
        if pads[0].pressed & BUTTON_START
            if (current_selection==0)
                current_level=1
                play_level(1)
            else
                goto mode howto_scr()  //go to main screen
                : preserves
        if (pads[0].pressed & BUTTON_UP)
            current_selection=0
        if (pads[0].pressed & BUTTON_DOWN)
            current_selection=1

        nmi // Wait for the next NMI
    //

// entrance point NMI
nmi howto_nmi() 
    // Update OAM and poll the pads:
    ppu_upload_oam_poll_pads(0)
    // Turn on rendering:
    {PPUMASK}(PPUMASK_ON | PPUMASK_NO_CLIP)
    // Reset the scroll
    ppu_reset_scroll(0, 0)
    //

// entrance point function
mode howto_scr()
: nmi howto_nmi
    // init vars
    current_level=0
    //
    {PPUCTRL}(0)  // Reset PPU control register for new level
    {PPUMASK}(0) // Reset PPU mask register for new level
    hide_oam(0)// Clear OAM to start fresh
    //
    // load the help screen made in NEXXT
    load_palette_from(@lev_level5)
    ppu_reset_addr($2000)
    for UU i=0; i<1024; i+=1
        {PPUDATA}(@help_screen_bytes{i})
    //
    // Tell the NES to trigger NMI once per frame
    {PPUCTRL}(PPUCTRL_NMI_ON)
    //
    while true
        update_pads()
        if pads[0].pressed & BUTTON_START
            goto mode main()  //go to main screen
            : preserves
        nmi // Wait for the next NMI
    //

nmi play_level_nmi()
    // we need to update GFXs while NMI, so we do this now, ONLY ONE metatile per frame
    if (num_ppuops_in_queue > 0)
        set_metatile_at_colrow(ppuop_col[ppuops_queue_index], ppuop_row[ppuops_queue_index], ppuop_new_metatile[ppuops_queue_index])
        ppuops_queue_index+=1
        if (ppuops_queue_index >= num_ppuops_in_queue)
            num_ppuops_in_queue=0
            ppuops_queue_index=0
    // Update OAM and poll the pads:
    ppu_upload_oam_poll_pads(0)
    // Turn on rendering:
    {PPUMASK}(PPUMASK_ON | PPUMASK_NO_CLIP)
    // Reset the scroll
    ppu_reset_scroll(0, 0)
    //

// The following mode shows 2 see-through screens and jumps to the next level
mode see_through_scr()
: nmi play_level_nmi
    //
    {PPUCTRL}(PPUCTRL_NMI_ON)
    //
    // show first see through screen
    U num_mt_written=0
    U x=0
    U y=0
    U margin_up=1
    U margin_left=0
    U margin_right=15
    U margin_down=14
    U direction=1 // 0=up 1=right 2=down 3=left
    while (num_mt_written<240)
        hide_oam(0)
        UU pos=((y<<4)+x)
        attempt_new_mt_change(x, y, inter_scr_mt_map{pos}, false) // I need to use this function because the PPU is painting right now
        num_mt_written+=1
        //
        if (direction==0)
            if (y==margin_up)
                direction=1
                margin_up+=1
                x+=1
            else
                y-=1
        else
            if (direction==1)
                if (x==margin_right)
                    direction=2
                    margin_right-=1
                    y+=1
                else
                    x+=1
            else
                if (direction==2)
                    if (y==margin_down)
                        direction=3
                        margin_down-=1
                        x-=1
                    else
                        y+=1
                else
                    if (direction==3)
                        if (x==margin_left)
                            direction=0
                            margin_left+=1
                            y-=1
                        else
                            x-=1
        //
        nmi // Wait for the next NMI
    //
    // show second see through screen
    num_mt_written=0
    x=0
    y=0
    while (num_mt_written<240)
        hide_oam(0)
        UU pos=((y<<4)+x)
        attempt_new_mt_change(x, y, pr_lvl_scr_mt_map{pos}, false) // I need to use this function because the PPU is painting right now
        num_mt_written+=1
        if (x==15)
            x=0
            y+=1
        else
            x+=1
        nmi // Wait for the next NMI
    //
    current_level+=1
    play_level(current_level) // finally, we start the new level


mode level1()
: nmi play_level_nmi
    // init vars
    current_level=1
    //
    {PPUCTRL}(0)  // Reset PPU control register for new level
    {PPUMASK}(0) // Reset PPU mask register for new level
    hide_oam(0)// Clear OAM to start fresh
    load_screen(@lev_level5) // this is necessary because we want the palette
    // Tell the NES to trigger NMI once per frame:
    {PPUCTRL}(PPUCTRL_NMI_ON)
    //
    
    // prepare the level squares values
    level_squares[0].active=false
    //
    level_squares[1].active=false
    //
    level_squares[2].active=false
    //
    level_squares[3].active=true
    level_squares[3].north=GREEN
    level_squares[3].east=RED
    level_squares[3].south=YELLOW
    level_squares[3].west=VIOLET
    //
    level_squares[4].active=true
    level_squares[4].north=YELLOW
    level_squares[4].east=VIOLET
    level_squares[4].south=GREEN
    level_squares[4].west=RED
    //
    level_squares[5].active=true
    level_squares[5].north=YELLOW
    level_squares[5].east=GREEN
    level_squares[5].south=RED
    level_squares[5].west=VIOLET
    //
    level_squares[6].active=false
    //
    level_squares[7].active=false
    //
    level_squares[8].active=false
    //
    copy_to_solved_squares()
    randomize_lvl() // randomize level
    redraw_all_sqrs()
    //

    while true
        update_pads()
        move_player()
        update_sprites() 
        check_if_success()
        nmi // Wait for the next NMI
    //

